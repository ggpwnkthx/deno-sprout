{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.minimax.io/anthropic/v1",
        "apiKey": "{env:MINIMAX_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "MiniMax-M2.7": {
          "name": "MiniMax-M2.7"
        }
      }
    }
  },
  "model": "minimax/MiniMax-M2.7",
  "small_model": "minimax/MiniMax-M2.7",
  "formatter": {
    "deno-fmt": {
      "command": [
        "deno",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs"
      ]
    }
  },
  "default_agent": "deno-lead",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.env.sample": "allow",
      "*.env.template": "allow",
      "*.pem": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "**/credentials.json": "deny",
      "**/.npmrc": "deny"
    },
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git ls-files*": "allow",
      "find *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "deno task*": "allow",
      "deno fmt*": "allow",
      "deno lint*": "allow",
      "deno check*": "allow",
      "deno test*": "allow",
      "deno info*": "allow",
      "deno cache*": "ask"
    },
    "skill": {
      "*": "deny",
      "opencode-session-discipline": "allow",
      "critical-code-review": "allow",
      "deno-*": "allow"
    },
    "task": {
      "*": "deny",
      "deno-*": "allow"
    },
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "watcher": {
    "ignore": [
      ".opencode/**",
      "node_modules/**",
      ".git/**"
    ]
  }
}
